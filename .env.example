# Copie este arquivo para .env e ajuste os valores
# No Coolify, configure estas variáveis no painel de Environment Variables

# ─── Banco de dados MariaDB ───────────────────────────────────
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=disc_vanguardia
DB_USER=disc_user
DB_PASS=DiscVanguardia@2024
MARIADB_ROOT_PASSWORD=RootVanguardia@2024

# ─── Autenticação admin ───────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Vanguardia@2024

# ─── JWT (mude para uma string aleatória longa em produção) ──
JWT_SECRET=vanguardia-jwt-secret-mude-em-producao
